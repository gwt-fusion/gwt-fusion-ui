{
  "schemaVersion": 1,
  "project": "GWT Fusion",
  "description": "Machine-readable catalog for coding agents that generate GWT Fusion code.",
  "modules": [
    {
      "artifactId": "gwt-fusion-ui",
      "rootPackage": "org.gwtfusion.ui",
      "purpose": "DOM-based UI components and theme APIs."
    },
    {
      "artifactId": "gwt-fusion-icons-lucide",
      "rootPackage": "org.gwtfusion.icons.lucide",
      "purpose": "Generated Lucide icon factories for use with the UI Icon APIs."
    },
    {
      "artifactId": "gwt-fusion-router",
      "rootPackage": "org.gwtfusion.router",
      "purpose": "Standalone client router that renders HTMLElement values."
    }
  ],
  "globalRules": [
    "Use elemental2.dom for DOM nodes.",
    "Do not use classic GWT widgets.",
    "Prefer component factory methods and fluent APIs.",
    "Prefer enum variants and sizes.",
    "Use semantic listeners such as onValueChange, onOpenChange, onCheckedChange, and onItemSelect.",
    "Do not build dynamic Tailwind class names.",
    "Use DirectionManager for document direction and logical START/END overlay sides when placement should follow LTR/RTL."
  ],
  "components": [
    { "name": "Accordion", "category": "Layout", "package": "org.gwtfusion.ui.component.accordion", "factory": "Accordion.create()", "example": "Accordion.create()" },
    { "name": "Alert", "category": "Feedback", "package": "org.gwtfusion.ui.component.alert", "factory": "Alert.create(String, String)", "variants": ["DEFAULT", "DESTRUCTIVE"], "example": "Alert.create(\"Heads up\", \"Check your settings.\")" },
    { "name": "AlertDialog", "category": "Overlays", "package": "org.gwtfusion.ui.component.alertdialog", "factory": "AlertDialog.create()", "events": ["onOpenChange"], "example": "AlertDialog.create()" },
    { "name": "AspectRatio", "category": "Layout", "package": "org.gwtfusion.ui.component.aspectratio", "factory": "AspectRatio.create()", "example": "AspectRatio.create().ratio(16, 9)" },
    { "name": "Autocomplete", "category": "Advanced UX", "package": "org.gwtfusion.ui.component.autocomplete", "factory": "Autocomplete.create()", "events": ["onValueChange", "onOpenChange"], "example": "Autocomplete.create().placeholder(\"Search...\")" },
    { "name": "Avatar", "category": "Data Display", "package": "org.gwtfusion.ui.component.avatar", "factory": "Avatar.create()", "sizes": ["SM", "MD", "LG"], "example": "Avatar.create().fallback(\"NB\")" },
    { "name": "Badge", "category": "Actions", "package": "org.gwtfusion.ui.component.badge", "factory": "Badge.create(String)", "variants": ["DEFAULT", "SECONDARY", "DESTRUCTIVE", "OUTLINE"], "example": "Badge.create(\"Beta\").variant(BadgeVariant.SECONDARY)" },
    { "name": "Breadcrumb", "category": "Navigation", "package": "org.gwtfusion.ui.component.breadcrumb", "factory": "Breadcrumb.create()", "example": "Breadcrumb.create()" },
    { "name": "Button", "category": "Actions", "package": "org.gwtfusion.ui.component.button", "factory": "Button.create(String)", "variants": ["DEFAULT", "DESTRUCTIVE", "SECONDARY", "OUTLINE", "GHOST", "LINK"], "sizes": ["SM", "MD", "LG", "ICON"], "events": ["onClick"], "example": "Button.create(\"Save\").variant(ButtonVariant.DEFAULT)" },
    { "name": "ButtonGroup", "category": "Actions", "package": "org.gwtfusion.ui.component.buttongroup", "factory": "ButtonGroup.create()", "example": "ButtonGroup.create().add(Button.create(\"One\"))" },
    { "name": "Calendar", "category": "Data Display", "package": "org.gwtfusion.ui.component.calendar", "factory": "Calendar.create()", "events": ["onValueChange"], "example": "Calendar.create()" },
    { "name": "Card", "category": "Layout", "package": "org.gwtfusion.ui.component.card", "factory": "Card.create()", "example": "Card.create().add(Card.header().add(Card.title(\"Title\")))" },
    { "name": "Carousel", "category": "Data Display", "package": "org.gwtfusion.ui.component.carousel", "factory": "Carousel.create()", "example": "Carousel.create()" },
    { "name": "Checkbox", "category": "Forms", "package": "org.gwtfusion.ui.component.checkbox", "factory": "Checkbox.create()", "events": ["onCheckedChange"], "example": "Checkbox.create().checked(true).onCheckedChange(checked -> {})" },
    { "name": "CodeBlock", "category": "Layout", "package": "org.gwtfusion.ui.component.code", "factory": "CodeBlock.create(String)", "example": "CodeBlock.create(code).language(\"java\")" },
    { "name": "Collapsible", "category": "Layout", "package": "org.gwtfusion.ui.component.collapsible", "factory": "Collapsible.create()", "events": ["onOpenChange"], "example": "Collapsible.create()" },
    { "name": "Combobox", "category": "Advanced UX", "package": "org.gwtfusion.ui.component.combobox", "factory": "Combobox.create()", "events": ["onValueChange", "onOpenChange"], "example": "Combobox.create().placeholder(\"Select...\")" },
    { "name": "CommandMenu", "category": "Advanced UX", "package": "org.gwtfusion.ui.component.command", "factory": "CommandMenu.create()", "events": ["onValueChange", "onItemSelect"], "example": "CommandMenu.create().item(\"open\", \"Open\")" },
    { "name": "CommandPalette", "category": "Advanced UX", "package": "org.gwtfusion.ui.component.command", "factory": "CommandPalette.create()", "events": ["onOpenChange"], "example": "CommandPalette.create()" },
    { "name": "ContextMenu", "category": "Overlays", "package": "org.gwtfusion.ui.component.contextmenu", "factory": "ContextMenu.create()", "events": ["onOpenChange"], "example": "ContextMenu.create()" },
    { "name": "DataTable", "category": "Data Display", "package": "org.gwtfusion.ui.component.datatable", "factory": "DataTable.create()", "example": "DataTable.create()" },
    { "name": "DatePicker", "category": "Data Display", "package": "org.gwtfusion.ui.component.datepicker", "factory": "DatePicker.create()", "events": ["onValueChange", "onOpenChange"], "example": "DatePicker.create()" },
    { "name": "Dialog", "category": "Overlays", "package": "org.gwtfusion.ui.component.dialog", "factory": "Dialog.create()", "events": ["onOpenChange"], "example": "Dialog.create()" },
    { "name": "Drawer", "category": "Overlays", "package": "org.gwtfusion.ui.component.drawer", "factory": "Drawer.create()", "events": ["onOpenChange"], "example": "Drawer.create()" },
    { "name": "DropdownMenu", "category": "Overlays", "package": "org.gwtfusion.ui.component.dropdown", "factory": "DropdownMenu.create()", "events": ["onOpenChange", "onItemSelect"], "example": "DropdownMenu.create()" },
    { "name": "EmptyState", "category": "Feedback", "package": "org.gwtfusion.ui.component.emptystate", "factory": "EmptyState.create()", "example": "EmptyState.create().title(\"No results\")" },
    { "name": "FormField", "category": "Forms", "package": "org.gwtfusion.ui.component.form", "factory": "FormField.create()", "example": "FormField.create()" },
    { "name": "HoverCard", "category": "Overlays", "package": "org.gwtfusion.ui.component.hovercard", "factory": "HoverCard.create()", "events": ["onOpenChange"], "example": "HoverCard.create()" },
    { "name": "Icon", "category": "Media", "package": "org.gwtfusion.ui.component.icon", "factory": "Icon.create()", "example": "LucideIcons.search()" },
    { "name": "Input", "category": "Forms", "package": "org.gwtfusion.ui.component.input", "factory": "Input.create()", "events": ["onValueChange"], "example": "Input.create().type(\"email\").placeholder(\"Email\")" },
    { "name": "InputGroup", "category": "Forms", "package": "org.gwtfusion.ui.component.inputgroup", "factory": "InputGroup.create()", "example": "InputGroup.create().input(Input.create())" },
    { "name": "Item", "category": "Data Display", "package": "org.gwtfusion.ui.component.item", "factory": "Item.create()", "example": "Item.create().title(\"Inbox\")" },
    { "name": "Kbd", "category": "Data Display", "package": "org.gwtfusion.ui.component.kbd", "factory": "Kbd.create(String)", "example": "Kbd.create(\"Ctrl K\")" },
    { "name": "Label", "category": "Forms", "package": "org.gwtfusion.ui.component.label", "factory": "Label.create(String)", "example": "Label.create(\"Email\").forId(\"email\")" },
    { "name": "MultiSelect", "category": "Advanced UX", "package": "org.gwtfusion.ui.component.multiselect", "factory": "MultiSelect.create()", "events": ["onValueChange", "onOpenChange"], "example": "MultiSelect.create().placeholder(\"Select options\")" },
    { "name": "NativeSelect", "category": "Forms", "package": "org.gwtfusion.ui.component.select", "factory": "NativeSelect.create()", "events": ["onValueChange"], "example": "NativeSelect.create().option(\"light\", \"Light\")" },
    { "name": "Pagination", "category": "Navigation", "package": "org.gwtfusion.ui.component.pagination", "factory": "Pagination.create()", "events": ["onValueChange"], "example": "Pagination.create().page(1).totalPages(10)" },
    { "name": "Popover", "category": "Overlays", "package": "org.gwtfusion.ui.component.popover", "factory": "Popover.create()", "events": ["onOpenChange"], "example": "Popover.create()" },
    { "name": "Progress", "category": "Feedback", "package": "org.gwtfusion.ui.component.progress", "factory": "Progress.create()", "example": "Progress.create().value(60)" },
    { "name": "RadioGroup", "category": "Forms", "package": "org.gwtfusion.ui.component.radio", "factory": "RadioGroup.create()", "events": ["onValueChange"], "example": "RadioGroup.create().option(\"light\", \"Light\")" },
    { "name": "Resizable", "category": "Advanced UX", "package": "org.gwtfusion.ui.component.resizable", "factory": "Resizable.create()", "example": "Resizable.create()" },
    { "name": "ScrollArea", "category": "Layout", "package": "org.gwtfusion.ui.component.scrollarea", "factory": "ScrollArea.create()", "example": "ScrollArea.create()" },
    { "name": "Separator", "category": "Layout", "package": "org.gwtfusion.ui.component.separator", "factory": "Separator.create()", "example": "Separator.create()" },
    { "name": "Sheet", "category": "Overlays", "package": "org.gwtfusion.ui.component.sheet", "factory": "Sheet.create()", "events": ["onOpenChange"], "example": "Sheet.create()" },
    { "name": "Skeleton", "category": "Feedback", "package": "org.gwtfusion.ui.component.skeleton", "factory": "Skeleton.create()", "example": "Skeleton.create().classes(\"h-4 w-32\")" },
    { "name": "Slider", "category": "Forms", "package": "org.gwtfusion.ui.component.slider", "factory": "Slider.create()", "events": ["onValueChange", "onValueCommit"], "example": "Slider.create().min(0).max(100).value(50)" },
    { "name": "Spinner", "category": "Feedback", "package": "org.gwtfusion.ui.component.spinner", "factory": "Spinner.create()", "sizes": ["SM", "MD", "LG"], "example": "Spinner.create()" },
    { "name": "StatusIndicator", "category": "Feedback", "package": "org.gwtfusion.ui.component.status", "factory": "StatusIndicator.create(String)", "variants": ["SUCCESS", "WARNING", "ERROR", "INFO", "NEUTRAL"], "example": "StatusIndicator.create(\"Online\")" },
    { "name": "Switch", "category": "Forms", "package": "org.gwtfusion.ui.component.switcher", "factory": "Switch.create()", "events": ["onCheckedChange"], "example": "Switch.create().checked(true)" },
    { "name": "Table", "category": "Data Display", "package": "org.gwtfusion.ui.component.table", "factory": "Table.create()", "example": "Table.create()" },
    { "name": "Tabs", "category": "Layout", "package": "org.gwtfusion.ui.component.tabs", "factory": "Tabs.create()", "events": ["onValueChange"], "example": "Tabs.create().addTab(\"preview\", \"Preview\", content)" },
    { "name": "Textarea", "category": "Forms", "package": "org.gwtfusion.ui.component.textarea", "factory": "Textarea.create()", "events": ["onValueChange"], "example": "Textarea.create().placeholder(\"Message\")" },
    { "name": "Timeline", "category": "Data Display", "package": "org.gwtfusion.ui.component.timeline", "factory": "Timeline.create()", "example": "Timeline.create()" },
    { "name": "Toast", "category": "Feedback", "package": "org.gwtfusion.ui.component.toast", "factory": "Toast.create()", "example": "Toast.create().title(\"Saved\")" },
    { "name": "ToastManager", "category": "Feedback", "package": "org.gwtfusion.ui.component.toast", "factory": "ToastManager.create()", "example": "ToastManager.create().show(Toast.create().title(\"Saved\"))" },
    { "name": "Toggle", "category": "Actions", "package": "org.gwtfusion.ui.component.toggle", "factory": "Toggle.create(String)", "events": ["onPressedChange"], "example": "Toggle.create(\"Bold\").pressed(true)" },
    { "name": "ToggleGroup", "category": "Actions", "package": "org.gwtfusion.ui.component.togglegroup", "factory": "ToggleGroup.create()", "events": ["onValueChange"], "example": "ToggleGroup.create()" },
    { "name": "Tooltip", "category": "Overlays", "package": "org.gwtfusion.ui.component.tooltip", "factory": "Tooltip.create()", "example": "Tooltip.create()" },
    { "name": "Typography", "category": "Layout", "package": "org.gwtfusion.ui.component.typography", "factory": "Typography.*", "example": "Typography.h1(\"Heading\")" }
  ],
  "nonComponentApis": [
    { "name": "ThemeManager", "package": "org.gwtfusion.ui.theme", "example": "ThemeManager.setMode(ThemeMode.DARK)" },
    { "name": "DirectionManager", "package": "org.gwtfusion.ui.theme", "example": "DirectionManager.set(Direction.RTL)" },
    { "name": "LucideIcons", "package": "org.gwtfusion.icons.lucide", "example": "LucideIcons.search()" },
    { "name": "Router", "package": "org.gwtfusion.router", "example": "Router.create(HistoryStrategy.hash()).route(\"/\", context -> homeElement())" }
  ]
}
